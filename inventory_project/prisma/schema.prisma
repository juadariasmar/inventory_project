// Esquema de base de datos para Sistema de Inventarios

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  USUARIO
}

enum Permiso {
  VER_ANALISIS
  EXPORTAR_REPORTES
  REGISTRAR_MOVIMIENTOS
  REALIZAR_VENTAS
  // Esta rama (C) solo usa REGISTRAR_MOVIMIENTOS y REALIZAR_VENTAS en su
  // UI/logica, pero el enum debe incluir todos los valores que existen en
  // la BD para que Prisma no falle al hidratar registros con permisos de
  // ramas hermanas.
  AGREGAR_STOCK
  DESCONTAR_STOCK
}

model Usuario {
  id            Int         @id @default(autoincrement())
  nombreUsuario String      @unique
  contrasena    String
  nombre        String
  rol           Rol         @default(USUARIO)
  permisos      Permiso[]   @default([])
  creadoEn      DateTime    @default(now())
  auditorias    Auditoria[]
  ventas        Venta[]
}

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique
  // Prefijo usado para los codigos de los productos de esta categoria
  // (ej. "BEB", "ALI"). Se rellena en migracion para todas las categorias
  // existentes y es obligatorio para nuevas.
  prefijo   String     @unique
  productos Producto[]
}

model Producto {
  id          Int          @id @default(autoincrement())
  nombre      String
  descripcion String?
  codigo      String       @unique
  precio      Float
  cantidad    Int          @default(0)
  stockMinimo Int          @default(1)
  // Categoria obligatoria. Los productos sin categoria previa se reasignan
  // a la categoria "Sin clasificar" en la migracion.
  categoriaId Int
  categoria   Categoria    @relation(fields: [categoriaId], references: [id])
  movimientos Movimiento[]
  itemsVenta  ItemVenta[]
  creadoEn    DateTime     @default(now())
}

model Movimiento {
  id         Int      @id @default(autoincrement())
  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])
  tipo       String   // "entrada" o "salida"
  cantidad   Int
  notas      String?
  ventaId    Int?
  venta      Venta?   @relation(fields: [ventaId], references: [id], onDelete: SetNull)
  creadoEn   DateTime @default(now())

  @@index([ventaId])
}

model Venta {
  id          Int          @id @default(autoincrement())
  vendedorId  Int?
  vendedor    Usuario?     @relation(fields: [vendedorId], references: [id], onDelete: SetNull)
  total       Float
  notas       String?
  items       ItemVenta[]
  movimientos Movimiento[]
  creadoEn    DateTime     @default(now())

  @@index([creadoEn(sort: Desc)])
  @@index([vendedorId])
}

model ItemVenta {
  id             Int      @id @default(autoincrement())
  ventaId        Int
  venta          Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  productoId     Int
  producto       Producto @relation(fields: [productoId], references: [id])
  cantidad       Int
  precioUnitario Float
  subtotal       Float

  @@index([ventaId])
  @@index([productoId])
}

model Auditoria {
  id        Int      @id @default(autoincrement())
  usuarioId Int?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  accion    String   // CREAR | ACTUALIZAR | ELIMINAR | LOGIN | LOGIN_FALLIDO
  entidad   String   // Producto | Categoria | Movimiento | Usuario | Sesion
  entidadId Int?
  datos     Json?    // { antes: {...}, despues: {...} } o detalles especificos del evento
  ip        String?
  creadoEn  DateTime @default(now())

  @@index([creadoEn(sort: Desc)])
  @@index([usuarioId])
  @@index([entidad, entidadId])
  @@index([accion])
}
