# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# SQLite local (ya no se usa en producción)
*.db
*.db-journal

# ===== Android / Gradle (módulo /android) =====
# Artefactos de compilación que NO deben versionarse (se regeneran al compilar)
android/.gradle/
android/build/
android/app/build/
android/.kotlin/
android/.idea/
android/local.properties
android/captures/
android/*.iml
android/app/*.iml
android/app/release/
*.apk.idsig

# playwright
/test-results/
/playwright-report/
/playwright/.cache/

# Agent and temporary files
task-*.md
task-*.diff
check-db.ts
implementation_plan.md
