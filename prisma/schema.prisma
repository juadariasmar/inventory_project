// Esquema de base de datos para Sistema de Inventarios

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Only use directUrl for Prisma migrate - uses unpooled for full SQL support
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Rol {
  ADMIN
  USUARIO
}

enum Permiso {
  VER_ANALISIS
  EXPORTAR_REPORTES
  REGISTRAR_MOVIMIENTOS
  REALIZAR_VENTAS
  // Esta rama (C) solo usa REGISTRAR_MOVIMIENTOS y REALIZAR_VENTAS en su
  // UI/logica, pero el enum debe incluir todos los valores que existen en
  // la BD para que Prisma no falle al hidratar registros con permisos de
  // ramas hermanas.
  AGREGAR_STOCK
  DESCONTAR_STOCK
}

enum EstadoUsuario {
  PENDIENTE // registrado, esperando aprobacion del admin
  ACTIVO // aprobado, puede operar normalmente
  SUSPENDIDO // bloqueado por el admin
}

enum EstadoInvitacion {
  PENDIENTE
  ACEPTADA
  EXPIRADA
  CANCELADA
}

enum TipoNotificacion {
  STOCK_BAJO
  STOCK_CRITICO
  COTIZACION_POR_VENCER
  PRODUCTO_SIN_MOVIMIENTO
  INVITACION_ACEPTADA
  USUARIO_REGISTRADO
}

model Notificacion {
  id        Int              @id @default(autoincrement())
  tipo      TipoNotificacion
  titulo    String
  mensaje   String?
  link      String?
  leida     Boolean          @default(false)
  leidaEn   DateTime?
  creadoEn  DateTime         @default(now())

  usuarioId String?
  usuario   Usuario?         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  empresaId String
  empresa   Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, leida])
  @@index([empresaId, usuarioId, leida])
  @@index([creadoEn(sort: Desc)])
}

model Cliente {
  id        Int       @id @default(autoincrement())
  nombre    String
  documento String?   @unique
  email     String?
  telefono  String?
  direccion String?
  notas     String?
  creadoEn  DateTime  @default(now())

  ventas        Venta[]
  cotizaciones  Cotizacion[]

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([nombre])
}

model Invitacion {
  id          String           @id @default(cuid())
  email       String
  empresaId   String
  empresa     Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  token       String           @unique @default(cuid())
  rol         Rol              @default(USUARIO)
  estado      EstadoInvitacion @default(PENDIENTE)
  expiraEn    DateTime
  aceptadaEn  DateTime?
  creadoEn    DateTime         @default(now())
  creadoPorId String?
  creadoPor   Usuario?         @relation("InvitacionCreadaPor", fields: [creadoPorId], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([empresaId])
  @@index([email])
}


model Empresa {
  id       String   @id @default(cuid())
  nombre   String
  creadoEn DateTime @default(now())

  usuarios           Usuario[]
  categorias         Categoria[]
  productos          Producto[]
  ventas             Venta[]
  cotizaciones       Cotizacion[]
  auditorias         Auditoria[]
  Movimiento         Movimiento[]
  proveedores        Proveedor[]
  ordenesCompra      OrdenCompra[]
  configuracion      ConfiguracionEmpresa?
  invitaciones       Invitacion[]
  notificaciones     Notificacion[]
  clientes           Cliente[]
  historialPrecios   HistorialPrecio[]
}

model ConfiguracionEmpresa {
  id                  String   @id @default(cuid())
  empresaId           String   @unique
  empresa             Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  moneda              String   @default("COP")
  simboloMoneda       String   @default("$")
  impuestos           Float    @default(0.19)
  logoUrl             String?
  direccion           String?
  telefono            String?
  email               String?
  nombrePersonalizado String?
  creadoEn            DateTime @default(now())
  actualizadoEn       DateTime @updatedAt
}

model Usuario {
  id                     String        @id @default(cuid())
  neonAuthId             String        @unique // ID del usuario en neon_auth.user
  email                  String        @unique // email sincronizado desde Neon Auth
  nombre                 String
  estado                 EstadoUsuario @default(PENDIENTE)
  rol                    Rol           @default(USUARIO)
  permisos               Permiso[]     @default([])
  onboardingCompletado   Boolean       @default(false)
  creadoEn               DateTime      @default(now())
  auditorias             Auditoria[]
  ventas                 Venta[]       @relation("VentaVendedor")
  cancelaciones          Venta[]       @relation("VentaCanceladaPor")
  cotizaciones           Cotizacion[]  @relation("CotizacionVendedor")
  cotizacionesCanceladas Cotizacion[]  @relation("CotizacionCanceladaPor")

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  invitacionesCreadas Invitacion[] @relation("InvitacionCreadaPor")
  notificaciones      Notificacion[]
  historialPrecios    HistorialPrecio[] @relation("HistorialPrecioUsuario")

  @@index([empresaId])
}

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String
  // Prefijo usado para los codigos de los productos de esta categoria
  // (ej. "BEB", "ALI"). Se rellena en migracion para todas las categorias
  // existentes y es obligatorio para nuevas.
  prefijo   String
  productos Producto[]

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, nombre])
  @@unique([empresaId, prefijo])
  @@index([empresaId])
}

model Producto {
  id               Int               @id @default(autoincrement())
  nombre           String
  descripcion      String?
  codigo           String            @unique
  precio           Float
  cantidad         Int               @default(0)
  stockMinimo      Int               @default(1)
  // Categoria obligatoria. Los productos sin categoria previa se reasignan
  // a la categoria "Sin clasificar" en la migracion.
  categoriaId      Int
  categoria        Categoria         @relation(fields: [categoriaId], references: [id])
  movimientos      Movimiento[]
  itemsVenta       ItemVenta[]
  itemsCotizacion  ItemCotizacion[]
  itemsOrdenCompra OrdenCompraItem[]
  historialPrecios HistorialPrecio[]
  creadoEn         DateTime          @default(now())

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([empresaId, codigo])
}

model HistorialPrecio {
  id             Int      @id @default(autoincrement())
  productoId     Int
  producto       Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  precioAnterior Float
  precioNuevo    Float
  creadoEn       DateTime @default(now())
  cambiadoPorId  String?
  cambiadoPor    Usuario? @relation("HistorialPrecioUsuario", fields: [cambiadoPorId], references: [id], onDelete: SetNull)

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([productoId, creadoEn(sort: Desc)])
  @@index([empresaId])
}

enum TipoMovimiento {
  entrada
  salida
}

model Movimiento {
  id            Int            @id @default(autoincrement())
  productoId    Int
  producto      Producto       @relation(fields: [productoId], references: [id])
  tipo          TipoMovimiento
  cantidad      Int
  notas         String?
  ventaId       Int?
  venta         Venta?         @relation(fields: [ventaId], references: [id], onDelete: SetNull)
  ordenCompraId Int?
  ordenCompra   OrdenCompra?   @relation(fields: [ordenCompraId], references: [id], onDelete: SetNull)
  creadoEn      DateTime       @default(now())

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, tipo, creadoEn(sort: Desc)])
  @@index([ventaId])
  @@index([ordenCompraId])
}

model Venta {
  id                Int          @id @default(autoincrement())
  vendedorId        String?
  vendedor          Usuario?     @relation("VentaVendedor", fields: [vendedorId], references: [id], onDelete: SetNull)
  clienteId         Int?
  cliente           Cliente?     @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  total             Float
  notas             String?
  items             ItemVenta[]
  movimientos       Movimiento[]
  creadoEn          DateTime     @default(now())
  canceladaEn       DateTime?
  canceladaPorId    String?
  canceladaPor      Usuario?     @relation("VentaCanceladaPor", fields: [canceladaPorId], references: [id], onDelete: SetNull)
  motivoCancelacion String?
  // Si esta venta nacio de convertir una cotizacion, la cotizacion la apunta.
  cotizacionOrigen  Cotizacion?  @relation("CotizacionConvertida")

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, creadoEn(sort: Desc)])
  @@index([vendedorId])
  @@index([canceladaEn])
  @@index([clienteId])
}

model ItemVenta {
  id             Int      @id @default(autoincrement())
  ventaId        Int
  venta          Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  productoId     Int
  producto       Producto @relation(fields: [productoId], references: [id])
  cantidad       Int
  precioUnitario Float
  subtotal       Float

  @@index([ventaId])
  @@index([productoId])
}

enum EstadoCotizacion {
  PENDIENTE // activa: reserva stock mientras validaHasta > now
  CONVERTIDA // convertida a Venta (ventaId apunta a la venta resultante)
  CANCELADA // cancelada manualmente, libera stock
}

model Cotizacion {
  id                Int              @id @default(autoincrement())
  vendedorId        String?
  vendedor          Usuario?         @relation("CotizacionVendedor", fields: [vendedorId], references: [id], onDelete: SetNull)
  clienteId         Int?
  cliente           Cliente?         @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  total             Float
  notas             String?
  items             ItemCotizacion[]
  estado            EstadoCotizacion @default(PENDIENTE)
  validaHasta       DateTime
  creadoEn          DateTime         @default(now())
  // Cuando se convierte: estado = CONVERTIDA y ventaId apunta a la Venta creada.
  ventaId           Int?             @unique
  venta             Venta?           @relation("CotizacionConvertida", fields: [ventaId], references: [id], onDelete: SetNull)
  convertidaEn      DateTime?
  // Cuando se cancela.
  canceladaEn       DateTime?
  canceladaPorId    String?
  canceladaPor      Usuario?         @relation("CotizacionCanceladaPor", fields: [canceladaPorId], references: [id], onDelete: SetNull)
  motivoCancelacion String?

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, estado, validaHasta])
  @@index([creadoEn(sort: Desc)])
  @@index([vendedorId])
}

model ItemCotizacion {
  id             Int        @id @default(autoincrement())
  cotizacionId   Int
  cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  productoId     Int
  producto       Producto   @relation(fields: [productoId], references: [id])
  cantidad       Int
  precioUnitario Float
  subtotal       Float

  @@index([cotizacionId])
  @@index([productoId])
}

model Auditoria {
  id        Int      @id @default(autoincrement())
  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  accion    String // CREAR | ACTUALIZAR | ELIMINAR | LOGIN | LOGIN_FALLIDO
  entidad   String // Producto | Categoria | Movimiento | Usuario | Sesion
  entidadId String?
  datos     Json? // { antes: {...}, despues: {...} } o detalles especificos del evento
  ip        String?
  creadoEn  DateTime @default(now())

  empresaId String?
  empresa   Empresa? @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, creadoEn(sort: Desc)])
  @@index([usuarioId])
  @@index([entidad, entidadId])
  @@index([accion])
}

model HistorialMovimientos {
  id          Int      @id @default(autoincrement())
  usuarioId   String
  accion      String   // CREAR | MODIFICAR | ELIMINAR
  recursoId   Int      // ID del producto afectado
  descripcion String   // descripcion legible del cambio
  datosAntes  Json?    // snapshot del recurso antes del cambio
  datosDespues Json?   // snapshot del recurso despues del cambio
  ip          String?
  creadoEn    DateTime @default(now())

  empresaId String

  @@index([empresaId, creadoEn(sort: Desc)])
  @@index([usuarioId])
  @@index([recursoId])
  @@index([accion])
}

enum EstadoOrdenCompra {
  BORRADOR // creada, editable, aún no recibida
  RECIBIDA // recibida: generó movimientos de entrada (inmutable)
  CANCELADA // cancelada antes de recibir
}

model Proveedor {
  id        Int      @id @default(autoincrement())
  nombre    String
  nit       String?
  contacto  String?
  telefono  String?
  email     String?
  direccion String?
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  ordenes OrdenCompra[]

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
}

model OrdenCompra {
  id          Int               @id @default(autoincrement())
  proveedorId Int
  proveedor   Proveedor         @relation(fields: [proveedorId], references: [id])
  estado      EstadoOrdenCompra @default(BORRADOR)
  total       Float             @default(0)
  notas       String?
  items       OrdenCompraItem[]
  movimientos Movimiento[]
  creadoEn    DateTime          @default(now())
  recibidaEn  DateTime?

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([proveedorId])
  @@index([estado])
  @@index([creadoEn(sort: Desc)])
}

model OrdenCompraItem {
  id            Int         @id @default(autoincrement())
  ordenCompraId Int
  ordenCompra   OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  productoId    Int
  producto      Producto    @relation(fields: [productoId], references: [id])
  cantidad      Int
  costoUnitario Float
  subtotal      Float

  @@index([ordenCompraId])
  @@index([productoId])
}
